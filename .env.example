# YouTube Data API Configuration
YOUTUBE_API_KEY=your_youtube_api_key_here

# OpenAI API Configuration (Required for GPT-4o-mini pitch generation)
OPENAI_API_KEY=your_openai_api_key_here

# Voice Synthesis Configuration
# ─────────────────────────────
# Three backends available:
#
# 1. fishspeech (default) — Local s1-mini (0.5B). Free, no API key.
#    Best open-source Fish model. Supports 64+ emotion tags.
#    TTS_BACKEND=fishspeech
#    FISH_SPEECH_URL=http://localhost:8080
#
# 2. fishaudio — Cloud S1 (4B). ~$0.80/hr of audio. Proprietary.
#    Stronger emotion conditioning, higher quality.
#    TTS_BACKEND=fishaudio
#    FISH_API_KEY=your_fish_audio_api_key_here
#
# 3. coqui_xtts — Local XTTS-v2. Free, voice cloning from reference.
#    pip install TTS (model auto-downloads ~1.8GB on first use).
#    TTS_BACKEND=coqui_xtts
#
# 4. elevenlabs — Cloud. Requires ELEVENLABS_API_KEY.
#    TTS_BACKEND=elevenlabs

# Default: local Fish Speech server (s1-mini, open-source)
# TTS_BACKEND=fishspeech
# FISH_SPEECH_URL=http://localhost:8080

# Optional: Coqui XTTS-v2 (local, voice cloning from reference audio)
#   pip install torch torchaudio && pip install coqui-tts
#   Model downloads automatically ~1.8GB on first use.
#   Uses the same FISH_REF_AUDIO_PATH for voice cloning reference.
# TTS_BACKEND=coqui_xtts
# COQUI_LANGUAGE=en
# COQUI_GPU=true

# Optional: Fish Audio cloud (get key at fish.audio/app/api-keys)
# TTS_BACKEND=fishaudio
# FISH_API_KEY=your_fish_audio_api_key_here

# Fish Audio Settings (optional — defaults work well)
# FISH_REFERENCE_ID=narrator                       # Reference voice registered on local server
# FISH_REF_AUDIO_PATH=path/to/reference_voice.wav  # For inline voice cloning
# FISH_REF_AUDIO_TEXT=Transcript of the reference audio.
# FISH_SPEED=0.9                                   # 0.5 (slow) to 2.0 (fast)
# FISH_TEMPERATURE=0.7                             # 0.0–1.0 (lower=more consistent)

# Parallel synthesis — number of concurrent TTS worker threads (default: 4)
# Fish Speech local handles concurrency fine (server queues internally).
# Cloud backends (fishaudio, elevenlabs) support full parallelism.
# Set to 1 if your GPU runs out of VRAM during parallel synthesis.
# SYNTH_CONCURRENCY=4

# Narration scene-boundary breathing room (milliseconds of silence between scenes)
# Prevents narration from feeling rushed at scene transitions. Default: 300ms.
# NARRATION_PAD_MS=300

# ElevenLabs API Configuration (optional — only if TTS_BACKEND=elevenlabs)
# ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Pexels API Configuration (Required for stock footage - get free key at pexels.com/api)
PEXELS_API_KEY=your_pexels_api_key_here

# Pixabay API Configuration (Optional - CC0 stock footage - get free key at pixabay.com/api/docs)
PIXABAY_API_KEY=your_pixabay_api_key_here

# AWS Configuration (Optional - for budget monitoring)
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_DEFAULT_REGION=us-east-1
AWS_ACCOUNT_ID=your_aws_account_id_here

# Unsplash API (free — get key at https://unsplash.com/developers)
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here
